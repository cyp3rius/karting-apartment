---
import SiteLayout from "../../layouts/SiteLayout.astro";
import Section from "../../components/Section.astro";
import { AboutSection } from "../../components/AboutSection";
import { AmenitiesSection } from "../../components/AmenitiesSection";
import { ReviewsSection } from "../../components/ReviewsSection";
import { HomePage } from "../../components/HomePage";
import { Gallery } from "../../components/Gallery";
import { ExploreSection } from "../../components/ExploreSection";
import { ContactSection } from "../../components/ContactSection";
import { locales, type Locale } from "../../i18n/config";
import { t } from "../../i18n/translations";
import { apartment } from "../../data/apartment";

export function getStaticPaths() {
	return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale = lang as Locale;
const strings = t(locale);
---

<SiteLayout locale={locale}>
	<HomePage client:load locale={locale} hero={strings.hero} />

	<AboutSection client:visible strings={strings.about} />

	<Section id="amenities" tone="muted">
		<div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
			<AmenitiesSection client:visible strings={strings.amenities} />
		</div>
	</Section>

	<Section id="gallery" tone="white">
		<div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12">
				<h2 class="text-3xl sm:text-4xl font-bold mb-4">{strings.gallery.title}</h2>
				<p class="text-muted-foreground text-lg max-w-2xl mx-auto">{strings.gallery.subtitle}</p>
			</div>
			<Gallery client:load locale={locale} title="Karting Apartment" />
		</div>
	</Section>

	<Section id="reviews" tone="muted">
		<div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
			<ReviewsSection client:visible strings={strings.reviews} />
		</div>
	</Section>

	<Section id="nearby" tone="white">
		<div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
			<ExploreSection client:visible locale={locale} strings={strings.nearby} />
		</div>
	</Section>

	<Section id="contact" tone="muted">
		<div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
			<ContactSection
				client:visible
				strings={strings.contact}
				email={apartment.links.email}
				bookingUrl={apartment.links.booking}
				airbnbUrl={apartment.links.airbnb}
				mapUrl={apartment.links.map}
				managerUrl={apartment.links.manager}
				managerLogoUrl={apartment.links.managerLogo}
			/>
		</div>
	</Section>
</SiteLayout>

<script define:vars={{ locale }}>
	localStorage.setItem("locale", locale);
</script>
