---
import { getCollection } from "astro:content";
import BlockRenderer from "../components/blocks/BlockRenderer.astro";
import Toolbar from "../components/Toolbar.astro";
import TailwindShowcase from "../components/showcase/TailwindShowcase.astro";
import { ShadcnShowcase } from "../components/showcase/ShadcnShowcase";
import UIToggle from "../components/UIToggle.astro";
import AstroLogo from "../components/icons/AstroLogo.astro";
import StrapiLogo from "../components/icons/StrapiLogo.astro";
import TypeScriptLogo from "../components/icons/TypeScriptLogo.astro";
import AiNativeLogo from "../components/icons/AiNativeLogo.astro";
import PaintbrushIcon from "../components/icons/PaintbrushIcon.astro";
import "../styles/global.css";

import type {
	StrapiHomepage,
	StrapiContentHeroComponent,
} from "../types/strapi";

function preprocessSingleType(collection: any[]) {
	return collection[0]?.data || null;
}

let homepage: StrapiHomepage | null = null;

try {
	// @ts-ignore — collections are generated dynamically by @sensinum/astro-strapi-loader
	homepage = await getCollection("homepage").then(preprocessSingleType);
} catch {
	// Strapi not connected — fallback content will be used
}

if (!homepage) {
	homepage = {
		id: 1,
		documentId: "homepage",
		title: "Astro × Strapi Starter | Always Free, Always Open — by Sensinum",
		hero: {
			__component: "blocks.hero",
			id: 0,
			title: "Performance that leaders trust",
			subtitle:
				"The future of how you build is now — Astro 6 × Strapi, agent-ready today, not a roadmap promise for next quarter.",
			content: [
				{
					type: "paragraph",
					children: [
						{
							type: "text",
							text: "Zero JS by design, strong Lighthouse, defaults you deploy. Strapi Loader and Strapi Blocks connect Strapi to Astro — typed collections, rich text as components. Tailwind 4, shadcn, dark mode; Tailwind-first or React + shadcn. AI-native driven with ",
						},
						{ type: "text", text: "AGENTS.md", bold: true },
						{ type: "text", text: ", " },
						{ type: "text", text: ".ai/", bold: true },
						{ type: "text", text: ", and " },
						{ type: "text", text: ".cursor/rules", bold: true },
						{
							type: "text",
							text: " — in-tree for your team and agents.",
						},
					],
				},
			],
			cta: {
				label: "Explore Features",
				url: "#features",
			},
		},
		sections: [],
		examples: [],
		publishedAt: new Date().toISOString(),
		updatedAt: new Date().toISOString(),
	};
}

const pageTitle = homepage?.title || "Astro × Strapi Starter | Always Free, Always Open — by Sensinum";

const pageDescription =
	"The future of the stack is now: Astro 6, Strapi, Sensinum Loader & Blocks, Tailwind 4, shadcn, dark mode, strong Lighthouse — agent context via AGENTS.md, .ai/, and Cursor rules.";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={Astro.url.href} />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta
			name="description"
			content={pageDescription}
		/>
		<meta name="keywords" content="Astro, Strapi, AI-native, Cursor, agent skills, AGENTS.md, Tailwind CSS, shadcn/ui, starter, headless CMS, TypeScript" />
		<meta name="author" content="Sensinum — VirtusLab Group" />

		{/* Open Graph */}
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.href} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:image" content={new URL("/og-image.png", Astro.url).href} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="Astro × Strapi Starter" />
		<meta property="og:locale" content="en_US" />

		{/* Twitter Card */}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={new URL("/og-image.png", Astro.url).href} />

		{/* JSON-LD Structured Data */}
		<script is:inline type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "SoftwareSourceCode",
			"name": "Astro × Strapi Starter",
			"description": pageDescription,
			"url": "https://github.com/VirtusLab-Open-Source/astro-strapi-starter",
			"codeRepository": "https://github.com/VirtusLab-Open-Source/astro-strapi-starter",
			"programmingLanguage": ["TypeScript", "Astro", "CSS"],
			"runtimePlatform": "Node.js",
			"license": "https://opensource.org/licenses/MIT",
			"author": {
				"@type": "Organization",
				"name": "Sensinum",
				"url": "https://www.sensinum.com",
				"parentOrganization": {
					"@type": "Organization",
					"name": "VirtusLab Group",
					"url": "https://www.virtuslab.com"
				}
			},
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			}
		})} />

		<script is:inline>
			(function() {
				var stored = localStorage.getItem('theme');
				var systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (stored === 'dark' || (!stored && systemDark)) {
					document.documentElement.classList.add('dark');
				}
				var uiMode = localStorage.getItem('ui-mode') || 'tailwind';
				document.documentElement.setAttribute('data-ui', uiMode);
			})();
		</script>
	</head>

	<body class="min-h-screen flex flex-col bg-background text-foreground">
		<Toolbar />

		<main class="flex-1">

			{/* ── Hero ── */}
			{
				homepage?.hero && (
					<BlockRenderer
						data={homepage.hero as StrapiContentHeroComponent}
					/>
				)
			}

			{/* ── Trusted By ── */}
			<section class="glass border-x-0 border-b-0 rounded-none">
				<div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-10 py-14 lg:py-16">
					<p class="text-center text-xs font-medium uppercase tracking-widest text-muted-foreground mb-8">Trusted by</p>
					<div class="flex flex-wrap items-center justify-center gap-x-16 lg:gap-x-20 gap-y-8">
						<a href="https://terraproperty.gr" target="_blank" rel="noopener noreferrer" aria-label="Terra Property" class="logo-punch" style="animation-delay: 0s">
							<img src="https://www.sensinum.com/img/starter/logo-terra-property.svg" alt="Terra Property" class="h-14 brightness-0 dark:brightness-0 dark:invert" />
						</a>
						<a href="https://vuw.ai" target="_blank" rel="noopener noreferrer" aria-label="VUW.ai" class="logo-punch" style="animation-delay: 0.5s">
							<img src="https://www.sensinum.com/img/starter/logo-vuw.svg" alt="VUW.ai" class="h-6 brightness-0 dark:brightness-0 dark:invert" />
						</a>
						<a href="https://sensinum.com" target="_blank" rel="noopener noreferrer" aria-label="Sensinum" class="logo-punch" style="animation-delay: 1s">
							<img src="https://www.sensinum.com/img/starter/sensinum-on-light.svg" alt="Sensinum" class="h-5 brightness-0 dark:hidden" />
							<img src="https://www.sensinum.com/img/starter/sensinum-on-dark.svg" alt="Sensinum" class="h-5 hidden dark:block dark:brightness-100" />
						</a>
						<a href="https://virtuslab.com" target="_blank" rel="noopener noreferrer" aria-label="VirtusLab" class="logo-punch" style="animation-delay: 1.5s">
							<img src="https://www.sensinum.com/img/starter/logo-vl.svg" alt="VirtusLab" class="h-11 brightness-0 dark:brightness-0 dark:invert" />
						</a>
					</div>
				</div>
			</section>

			{/* ── Feature Grid (glass cards) ── */}
			<section id="features" class="relative overflow-hidden">
				<div class="absolute inset-0 bg-linear-to-b from-brand-50/40 via-transparent to-violet-50/30 dark:from-brand-950/40 dark:via-transparent dark:to-violet-950/30 pointer-events-none" />
			<div class="relative max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-10 py-24 lg:py-32">
				<h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-center mb-4">All inclusive, no compromises</h2>
					<p class="text-center text-muted-foreground mb-12 max-w-3xl mx-auto text-lg">
						The full stack you'd assemble yourself — already wired, tested, and ready.
					</p>
					<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 lg:gap-6">
						<div class="glass glow-border rounded-2xl p-6 lg:p-8 transition-all hover:-translate-y-1 border-primary/20">
							<div class="size-10 rounded-xl bg-violet-500/15 flex items-center justify-center mb-4">
								<AiNativeLogo class="size-5 text-violet-600 dark:text-violet-400" />
							</div>
							<h3 class="font-semibold mb-2 flex items-center flex-wrap gap-x-1.5">AI-native first <a href="https://github.com/VirtusLab-Open-Source/astro-strapi-starter/blob/main/AGENTS.md" target="_blank" rel="noopener noreferrer" aria-label="AGENTS.md on GitHub" class="text-muted-foreground hover:text-foreground transition-colors"><svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a></h3>
							<p class="text-sm text-muted-foreground">Agent context, skills under <code class="text-xs bg-muted/80 px-1 py-0.5 rounded">.ai/</code>, and scoped Cursor rules — extend the stack with your AI tools, not against them.</p>
						</div>
						<div class="glass glow-border rounded-2xl p-6 lg:p-8 transition-all hover:-translate-y-1">
							<div class="size-10 rounded-xl bg-[#3245FF]/15 flex items-center justify-center mb-4">
								<AstroLogo class="size-5 text-foreground" />
							</div>
							<h3 class="font-semibold mb-2 flex items-center gap-1.5">Astro 6 <a href="https://astro.build" target="_blank" rel="noopener noreferrer" aria-label="Astro website" class="text-muted-foreground hover:text-foreground transition-colors"><svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a></h3>
							<p class="text-sm text-muted-foreground">Ships zero JS by default. Islands architecture and SSR give you performance without trade-offs.</p>
						</div>
						<div class="glass glow-border rounded-2xl p-6 lg:p-8 transition-all hover:-translate-y-1">
							<div class="size-10 rounded-xl bg-indigo-500/15 flex items-center justify-center mb-4">
								<StrapiLogo class="size-5" colored />
							</div>
							<h3 class="font-semibold mb-2 flex items-center gap-1.5">Strapi CMS <a href="https://strapi.io" target="_blank" rel="noopener noreferrer" aria-label="Strapi website" class="text-muted-foreground hover:text-foreground transition-colors"><svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a></h3>
							<p class="text-sm text-muted-foreground">Content collections loaded automatically via dedicated loader. Rich text rendered with a single component.</p>
						</div>
						<div class="glass glow-border rounded-2xl p-6 lg:p-8 transition-all hover:-translate-y-1">
							<div class="size-10 rounded-xl bg-sky-500/15 flex items-center justify-center mb-4">
								<PaintbrushIcon class="size-5 text-sky-600 dark:text-sky-400" />
							</div>
							<h3 class="font-semibold mb-2 flex items-center flex-wrap gap-x-1.5 gap-y-1">
								<span class="inline-flex items-center gap-1.5">Tailwind CSS 4 <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" aria-label="Tailwind CSS website" class="text-muted-foreground hover:text-foreground transition-colors"><svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a></span>
								<span class="text-muted-foreground font-normal" aria-hidden="true">|</span>
								<span class="inline-flex items-center gap-1.5">shadcn/ui <a href="https://ui.shadcn.com" target="_blank" rel="noopener noreferrer" aria-label="shadcn/ui website" class="text-muted-foreground hover:text-foreground transition-colors"><svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a></span>
							</h3>
							<p class="text-sm text-muted-foreground">Tailwind 4 with OKLCH and theme tokens; shadcn/ui on Radix for React islands — add what you need via the CLI.</p>
						</div>
						<div class="glass glow-border rounded-2xl p-6 lg:p-8 transition-all hover:-translate-y-1">
							<div class="size-10 rounded-xl bg-primary/15 flex items-center justify-center mb-4">
								<svg class="size-5 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
							</div>
							<h3 class="font-semibold mb-2">Dark Mode</h3>
							<p class="text-sm text-muted-foreground">Respects system preferences, toggleable at runtime. Branded tokens adapt across every component.</p>
						</div>
						<div class="glass glow-border rounded-2xl p-6 lg:p-8 transition-all hover:-translate-y-1">
							<div class="size-10 rounded-xl bg-blue-600/15 flex items-center justify-center mb-4">
								<TypeScriptLogo class="size-5" colored />
							</div>
							<h3 class="font-semibold mb-2 flex items-center gap-1.5">TypeScript <a href="https://www.typescriptlang.org" target="_blank" rel="noopener noreferrer" aria-label="TypeScript website" class="text-muted-foreground hover:text-foreground transition-colors"><svg class="size-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a></h3>
							<p class="text-sm text-muted-foreground">Strict mode enabled. Pages, components, and Strapi schemas are fully typed end to end.</p>
						</div>
					</div>
				</div>
			</section>

			<div class="glass-divider" />

			{/* ── Why This Starter? ── */}
			<section class="relative">
				<div class="max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-10 py-24 lg:py-32">
				<h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-center mb-4">Why this starter?</h2>
					<p class="text-center text-muted-foreground mb-12 max-w-3xl mx-auto text-lg">
						Strategic advantages that save you days of setup and architectural decisions.
					</p>
					<div class="grid sm:grid-cols-2 gap-5 lg:gap-6">
						<div class="glass rounded-2xl p-6 lg:p-8 flex gap-4 transition-all hover:-translate-y-0.5">
							<div class="shrink-0 size-10 rounded-xl bg-brand-500/15 flex items-center justify-center">
								<svg class="size-5 text-brand-600 dark:text-brand-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
							</div>
							<div>
								<h3 class="font-semibold mb-1">Zero config</h3>
								<p class="text-sm text-muted-foreground">Strapi Loader, Blocks renderer, React integration, shadcn/ui, Inter font — all wired up. Just clone and build.</p>
							</div>
						</div>
						<div class="glass rounded-2xl p-6 lg:p-8 flex gap-4 transition-all hover:-translate-y-0.5">
							<div class="shrink-0 size-10 rounded-xl bg-violet-500/15 flex items-center justify-center">
								<svg class="size-5 text-violet-600 dark:text-violet-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
							</div>
							<div>
								<h3 class="font-semibold mb-1">Choose your UI</h3>
								<p class="text-sm text-muted-foreground">Pure Astro + Tailwind or React + shadcn/ui — both approaches ship side by side with a live toggle to compare.</p>
							</div>
						</div>
						<div class="glass rounded-2xl p-6 lg:p-8 flex gap-4 transition-all hover:-translate-y-0.5">
							<div class="shrink-0 size-10 rounded-xl bg-brand-500/15 flex items-center justify-center">
								<svg class="size-5 text-brand-600 dark:text-brand-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
							</div>
							<div>
								<h3 class="font-semibold mb-1">Built by subject matter experts</h3>
								<p class="text-sm text-muted-foreground">12+ years of experience. The largest open-source maintainer in the Strapi ecosystem and the only team fully dedicated to the Astro × Strapi stack.</p>
							</div>
						</div>
						<div class="glass rounded-2xl p-6 lg:p-8 flex gap-4 transition-all hover:-translate-y-0.5">
							<div class="shrink-0 size-10 rounded-xl bg-violet-500/15 flex items-center justify-center">
								<svg class="size-5 text-violet-600 dark:text-violet-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
							</div>
							<div>
								<h3 class="font-semibold mb-1">Deploy in minutes</h3>
								<p class="text-sm text-muted-foreground">Vercel, Netlify, or any Node host — clone, set two env vars, deploy. Production-ready from day one.</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<div class="glass-divider" />

			{/* ── Packages (glass cards with gradient accent) ── */}
			<section class="relative overflow-hidden">
				<div class="absolute inset-0 bg-linear-to-br from-brand-50/30 to-violet-50/30 dark:from-brand-950/35 dark:to-violet-950/30 pointer-events-none" />
				<div class="relative max-w-screen-2xl mx-auto px-4 sm:px-6 lg:px-10 py-24 lg:py-32">
				<h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-center mb-4">Powered by</h2>
					<p class="text-center text-muted-foreground mb-12 max-w-3xl mx-auto text-lg">
						Open-source packages built and maintained by <a href="https://sensinum.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-primary/80 transition-colors font-medium">Sensinum</a>.
					</p>
					<div class="grid sm:grid-cols-2 gap-5 lg:gap-6">
						<div class="glass glow-border rounded-2xl p-6 lg:p-8 flex flex-col transition-all hover:-translate-y-1">
							<div class="flex items-center gap-3 mb-3">
								<div class="size-8 rounded-lg bg-brand-500/15 flex items-center justify-center">
									<svg class="size-4 text-brand-600 dark:text-brand-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
								</div>
								<h3 class="font-bold text-lg">Strapi Loader</h3>
							</div>
							<p class="text-sm text-muted-foreground mb-4 flex-1">Seamlessly load Strapi collections into Astro's content layer. Type-safe, automatic schema generation.</p>
							<div class="flex gap-2 mb-4">
								<img src="https://img.shields.io/npm/v/%40sensinum%2Fastro-strapi-loader" alt="NPM Version" />
								<img src="https://img.shields.io/npm/dm/%40sensinum%2Fastro-strapi-loader" alt="NPM Downloads" />
							</div>
							<a href="https://github.com/VirtusLab-Open-Source/astro-strapi-loader" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:text-primary/80 transition-colors">
								View on GitHub
