			<script is:inline>
			(function() {
				document.querySelectorAll('[data-pkg-tabs]').forEach(function(container) {
					var tabs = container.querySelectorAll('.pkg-tab');
					var panels = container.querySelectorAll('.pkg-panel');
					var copyBtn = container.querySelector('[data-copy]');

					function activate(pkg) {
						tabs.forEach(function(t) {
							var active = t.getAttribute('data-pkg') === pkg;
							t.className = 'pkg-tab px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors ' +
								(active ? 'bg-primary text-primary-foreground' : 'bg-muted/50 text-muted-foreground hover:text-foreground');
						});
						panels.forEach(function(p) {
							p.classList.toggle('hidden', p.getAttribute('data-cmd') !== pkg);
						});
					}

					activate('npm');

					tabs.forEach(function(tab) {
						tab.addEventListener('click', function() {
							activate(this.getAttribute('data-pkg'));
						});
					});

					if (copyBtn) {
						copyBtn.addEventListener('click', function() {
							var visible = container.querySelector('.pkg-panel:not(.hidden)');
							if (visible) {
								navigator.clipboard.writeText(visible.textContent.trim());
								copyBtn.querySelector('.copy-icon').classList.add('hidden');
								copyBtn.querySelector('.check-icon').classList.remove('hidden');
								setTimeout(function() {
									copyBtn.querySelector('.copy-icon').classList.remove('hidden');
									copyBtn.querySelector('.check-icon').classList.add('hidden');
								}, 2000);
							}
						});
					}
				});
			})();
			</script>

