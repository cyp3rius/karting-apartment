---
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Karting Apartment</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>
	<body class="min-h-screen flex items-center justify-center bg-[#FAFAF8] text-[#6B6B6B]">
		<p class="animate-pulse text-sm">Loading…</p>
		<script is:inline>
			(function () {
				var stored = localStorage.getItem("locale");
				var locale = stored;
				if (!locale || ["en", "it", "pl"].indexOf(locale) === -1) {
					var lang = (navigator.language || "").toLowerCase();
					if (lang.indexOf("it") === 0) locale = "it";
					else if (lang.indexOf("pl") === 0) locale = "pl";
					else locale = "en";
				}
				window.location.replace("/" + locale + "/");
			})();
		</script>
	</body>
</html>
