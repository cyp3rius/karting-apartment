---
import { StrapiBlocks } from '@sensinum/astro-strapi-blocks';

import type { StrapiContentTextComponent } from '../../types/strapi';

type Props = {
    data: StrapiContentTextComponent;
};

const { data } = Astro.props;
---

<div class="prose prose-lg max-w-none">
    {data.title && (
        <h2 class="text-2xl lg:text-3xl font-bold text-foreground mb-6">
            {data.title}
        </h2>
    )}
    {data.content && (
        <div class="text-muted-foreground leading-relaxed [&_p]:mb-4 [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-4 [&_a:hover]:text-primary/80">
            <StrapiBlocks data={data.content} />
        </div>
    )}
</div>
