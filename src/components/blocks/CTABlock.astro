---
import type { StrapiContentCTAComponent } from "../../types/strapi";

type Props = {
    data: StrapiContentCTAComponent;
};

const { data } = Astro.props;
const {
    classes = "rounded-xl border border-border bg-muted/50 p-8 my-8 text-foreground",
} = data;
---

<div class={classes}>
    <div class="text-center">
        {
            data.title && (
                <h3 class="text-2xl lg:text-3xl font-bold mb-4">
                    {data.title}
                </h3>
            )
        }
        {
            data.shields && (
                <div class="flex justify-center p-2 mb-3">
                    <div class="flex justify-center gap-2 rounded-lg overflow-hidden bg-background/80 dark:bg-background/40 p-2 shadow-sm border border-border/50">
                        {data.shields.map((shield) => (
                            <img src={shield.url} alt={shield.label} />
                        ))}
                    </div>
                </div>
            )
        }
        {
            data.description && (
                <p class="text-lg lg:text-xl mb-6 text-muted-foreground">
                    {data.description}
                </p>
            )
        }
        {
            data.cta && (
                <a
                    href={data.cta.url}
                    class="inline-block bg-primary hover:bg-primary/90 text-primary-foreground font-semibold py-3 px-8 rounded-lg transition-colors shadow-sm"
                >
                    {data.cta.label}
                </a>
            )
        }
    </div>
</div>
