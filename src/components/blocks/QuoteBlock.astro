---
import type { StrapiContentQuoteComponent } from '../../types/strapi';

type Props = {
    data: StrapiContentQuoteComponent;
};

const { data } = Astro.props;
---

<blockquote class="bg-muted/50 border-l-4 border-primary/40 p-6 my-8 rounded-r-lg">
    <p class="text-xl lg:text-2xl text-foreground/90 italic leading-relaxed mb-4">
        "{data.quote}"
    </p>
    {data.author && (
        <footer class="text-muted-foreground font-medium">
            — {data.author}
        </footer>
    )}
</blockquote>
