---
import type { Locale } from "../i18n/config";
import type { PageMeta } from "../lib/seo";
import {
	buildJsonLdGraph,
	hreflangLinks,
	ogLocaleAlternates,
	ogLocaleMap,
	pageUrl,
} from "../lib/seo";
import { absoluteUrl, site } from "../data/site";

interface Props {
	locale: Locale;
	meta: PageMeta;
}

const { locale, meta } = Astro.props;

const canonical = pageUrl(locale);
const ogImage = absoluteUrl(site.ogImage);
const jsonLd = buildJsonLdGraph(locale, meta);
---

<!-- Primary meta -->
<link rel="canonical" href={canonical} />
<meta name="description" content={meta.description} />
<meta name="keywords" content={meta.keywords} />
<meta
	name="robots"
	content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>
<meta name="author" content={site.manager.name} />
<meta name="theme-color" content="#009246" />

<!-- Geo (legacy + local relevance) -->
<meta name="geo.region" content={site.geo.region} />
<meta name="geo.placename" content={site.geo.placename} />
<meta name="geo.position" content={`${site.geo.latitude};${site.geo.longitude}`} />
<meta name="ICBM" content={`${site.geo.latitude}, ${site.geo.longitude}`} />

<!-- hreflang -->
{
	hreflangLinks().map((link) => (
		<link rel="alternate" hreflang={link.hreflang} href={link.href} />
	))
}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={meta.title} />
<meta property="og:description" content={meta.description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={ogLocaleMap[locale]} />
{
	ogLocaleAlternates(locale).map((alt) => (
		<meta property="og:locale:alternate" content={alt} />
	))
}
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content={String(site.ogImageWidth)} />
<meta property="og:image:height" content={String(site.ogImageHeight)} />
<meta property="og:image:alt" content={meta.title} />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={meta.title} />
<meta name="twitter:description" content={meta.description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={meta.title} />

<!-- AI / GEO discoverability -->
<link rel="alternate" type="text/plain" href="/llms.txt" title="LLM site summary" />

<!-- Structured data -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
