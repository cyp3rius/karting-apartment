---
const tagManagerId = import.meta.env.PUBLIC_GOOGLE_TAG_MANAGER_ID?.trim();
if (!tagManagerId) return;
---

<!-- Google Tag Manager (injected after LCP via runAfterLcpStaggered) -->
<script define:vars={{ tagManagerId }} type="text/javascript" is:inline>
	(function () {
		function initGtm() {
			(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
				var f = d.getElementsByTagName(s)[0],
					j = d.createElement(s),
					dl = l != "dataLayer" ? "&l=" + l : "";
				j.async = true;
				j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
				f.parentNode.insertBefore(j, f);
			})(window, document, "script", "dataLayer", tagManagerId);
		}
		window.runAfterLcpStaggered(initGtm);
	})();
</script>
<!-- End Google Tag Manager -->
