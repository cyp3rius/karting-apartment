---
type Props = {
  class?: string;
};

const { class: className } = Astro.props;
---

<svg class={className} viewBox="0 0 256 256" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="32" xmlns="http://www.w3.org/2000/svg"><line x1="208" y1="128" x2="128" y2="208"/><line x1="192" y1="40" x2="40" y2="192"/></svg>
