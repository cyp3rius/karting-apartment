---
import type { Locale } from "../i18n/config";
import {
	resolveHostKind,
	unprefixedLocaleForHost,
} from "../i18n/config";
import { t } from "../i18n/translations";
import { SiteHeader } from "../components/SiteHeader";
import SeoHead from "../components/SeoHead.astro";
import SiteFooter from "../components/SiteFooter.astro";
import AfterLcp from "../components/special/AfterLcp.astro";
import GoogleTagManagerHead from "../components/special/GoogleTagManagerHead.astro";
import GoogleTagManagerBody from "../components/special/GoogleTagManagerBody.astro";
import "../styles/global.css";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const unprefixedLocale = unprefixedLocaleForHost(
	resolveHostKind(Astro.url.hostname),
);
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{strings.meta.title}</title>
		<SeoHead locale={locale} meta={strings.meta} />
		<AfterLcp />
		<GoogleTagManagerHead />
	</head>
	<body class="min-h-screen flex flex-col bg-background text-foreground antialiased">
		<GoogleTagManagerBody />
		<SiteHeader
			client:load
			locale={locale}
			unprefixedLocale={unprefixedLocale}
			strings={strings.nav}
		/>
		<main id="main-content" class="flex-1">
			<slot />
		</main>
		<SiteFooter
			locale={locale}
			unprefixedLocale={unprefixedLocale}
			nav={strings.nav}
			footer={strings.footer}
		/>
	</body>
</html>
